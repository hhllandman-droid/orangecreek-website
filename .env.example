# Payload CMS
PAYLOAD_SECRET=een-zeer-lange-en-ongeradenbare-secret-string

# PostgreSQL (bijv. Render Managed Postgres)
DATABASE_URI=postgresql://user:password@localhost:5432/orangecreek

# Optioneel: publieke server-URL voor absolute media-URLs en admin panel
NEXT_PUBLIC_SERVER_URL=https://orangecreek.co

# Bird e-mail (voor wachtwoord-reset en andere CMS-mails)
# Maak een API key aan in Bird → Developers → API keys (scope: emails:write)
BIRD_API_KEY=
BIRD_FROM_EMAIL=noreply@orangecreek.co
BIRD_FROM_NAME=Orange Creek
# BIRD_API_BASE=https://eu1.platform.bird.com

# Eenmalige admin-wachtwoordreset (verwijder na gebruik)
# ADMIN_EMAIL=info@orangecreek.co
# ADMIN_RESET_PASSWORD=een-tijdelijk-wachtwoord
# ADMIN_RESET_SECRET=lang-geheim-voor-api-admin-reset
